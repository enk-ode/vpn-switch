# ==============================================================================
# TEST CONFIG - Sanitized for vpn-switch testing
# All credentials, keys, and endpoints have been replaced with dummy values
# ==============================================================================

# The server you are connecting to is using a circuit in order to separate entry IP from exit IP
# The same entry IP allows to connect to multiple exit IPs in the same data center.

# If you want to explicitly select the exit IP corresponding to server TEST-RS#1 you need to
# append a special suffix to your OpenVPN username.
# Please use "testuser+b:1" in order to enforce exiting through TEST-RS#1.

# If you are a paying user you can also enable the VPN provider ad blocker (NetShield) or Moderate NAT:
# Use: "testuser+b:1+f1" to enable anti-malware filtering
# Use: "testuser+b:1+f2" to additionally enable ad-blocking filtering
# Use: "testuser+b:1+nr" to enable Moderate NAT
# Note that you can combine the "+nr" suffix with other suffixes.

client
dev tun
proto udp

remote 192.0.2.10 4569
remote 192.0.2.10 5060
remote 192.0.2.10 51820
remote 192.0.2.10 1194
remote 192.0.2.10 80

remote-random
resolv-retry infinite
nobind

cipher AES-256-GCM

setenv CLIENT_CERT 0
tun-mtu 1500
mssfix 0
persist-key
persist-tun

reneg-sec 0

remote-cert-tls server
auth-user-pass

script-security 2
up /etc/openvpn/update-resolv-conf
down /etc/openvpn/update-resolv-conf

