#!/bin/sh
#
# wg-resolvconf-down - WireGuard DNS cleanup script for FreeBSD
# Enhanced version with syslog integration
#

set -e

INTERFACE="${1:-wg0}"
RESOLVCONF="/sbin/resolvconf"

# Log for debugging via syslog
logger -t "wg-resolvconf" "DOWN: interface=$INTERFACE"

# Remove DNS configuration for interface
"$RESOLVCONF" -d "${INTERFACE}.inet"

logger -t "wg-resolvconf" "DOWN: Removed DNS for $INTERFACE"

# Restart local_unbound to pick up resolvconf changes (FreeBSD-specific)
# local_unbound doesn't auto-detect resolvconf updates with reload, needs restart
# Note: Using restart instead of reload because reload (SIGHUP) doesn't properly
# reload the forwarder configuration from resolvconf
if service local_unbound status >/dev/null 2>&1; then
    logger -t "wg-resolvconf" "DOWN: Restarting local_unbound DNS daemon"
    service local_unbound restart || logger -t "wg-resolvconf" "DOWN: Warning - failed to restart local_unbound"
fi

exit 0